{
  "name": "dailyearn-ai-backend",
  "version": "1.0.0",
  "description": "DailyEarn AI — Backend API server",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate:run": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^5.1.0",
    "drizzle-orm": "^0.44.0",
    "drizzle-kit": "^0.31.0",
    "pg": "^8.13.0",
    "redis": "^4.7.0",
    "bull": "^4.16.0",
    "@bull-board/express": "^6.6.0",
    "@bull-board/api": "^6.6.0",
    "@google/generative-ai": "^0.24.0",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "zod": "^3.24.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "express-rate-limit": "^7.5.0",
    "rate-limit-redis": "^4.2.0",
    "helmet": "^8.1.0",
    "cors": "^2.8.5",
    "isomorphic-dompurify": "^2.16.0",
    "uuid": "^11.1.0",
    "hashids": "^2.3.0",
    "dotenv": "^16.4.0",
    "cookie-parser": "^1.4.7"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^3.1.0",
    "supertest": "^7.1.0",
    "@types/pg": "^8.11.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/cors": "^2.8.17",
    "@types/bull": "^4.10.0",
    "@types/uuid": "^10.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/node": "^22.14.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
