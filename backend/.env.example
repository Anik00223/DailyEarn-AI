# ─── DailyEarn AI — Environment Variables ───
# Copy this file to .env and fill in all values.
# The app will crash with a descriptive error if any required variable is missing.

# ─── App ───
NODE_ENV=development
PORT=3001

# ─── PostgreSQL ───
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dailyearn

# ─── Redis ───
# Local: redis://localhost:6379
# Upstash: rediss://default:xxxxx@xxxxx.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ─── Google Gemini AI ───
GEMINI_API_KEY=your_gemini_api_key_here

# ─── JWT Secrets (min 64 characters each) ───
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_64_char_min_access_secret_here_generate_with_crypto_random_bytes
JWT_REFRESH_SECRET=your_64_char_min_refresh_secret_here_generate_with_crypto_random_bytes

# ─── Security ───
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:5173

# ─── Admin ───
# Used to access BullBoard queue dashboard at /admin/queues
# Min 32 characters
ADMIN_SECRET=your_32_char_min_admin_secret_for_bull_board
